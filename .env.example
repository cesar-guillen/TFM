# Copy to `.env` and adjust. Every value below matches the docker-compose.yml
# default — an absent .env gives exactly this configuration. Prefer picking a
# hardware profile instead of hand-tuning: docker-compose.gpu.yml /
# docker-compose.cpu.yml / docker-compose.basic.yml (see README). Values set
# here override the profile's defaults.

# Optional: make plain `docker compose up` use your chosen profile, e.g.:
# COMPOSE_FILE=docker-compose.yml:docker-compose.cpu.yml

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=5173
OLLAMA_PORT=11434

# Models. ollama-init pulls whatever is named here on the next `up` (first
# pull of a new model downloads it — a 2 GB model takes ~a minute).
# llama3.1:8b needs ~8 GB VRAM/RAM headroom; llama3.2:3b is the low-memory tier.
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Concurrency: MAP_WORKERS concurrent LLM mapping calls, matched by
# OLLAMA_NUM_PARALLEL server slots. Keep them equal; each slot costs KV-cache
# memory, so halve both on tight machines.
OLLAMA_NUM_PARALLEL=4
MAP_WORKERS=4

# -1 pins models in (V)RAM forever (warm runs always); a duration like `5m`
# releases the memory after idle time instead.
OLLAMA_KEEP_ALIVE=-1

# Skip remediation/boilerplate sections at indexing (false = ablation run).
SECTION_FILTER=true

# Data / storage paths (inside containers)
UPLOAD_DIR=/data/uploads
LAYERS_DIR=/data/layers
CHROMA_PERSIST_DIR=/data/chroma
ATTACK_STIX_DIR=/data/attack
