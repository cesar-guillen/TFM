# Copy to `.env` and adjust. Every value below matches the docker-compose.yml
# default — an absent .env gives exactly this configuration. Prefer picking a
# hardware profile instead of hand-tuning: docker-compose.gpu.yml /
# docker-compose.cpu.yml / docker-compose.basic.yml (see README). Values set
# here override the profile's defaults.

# Optional: make plain `docker compose up` use your chosen profile, e.g.:
# COMPOSE_FILE=docker-compose.yml:docker-compose.cpu.yml

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=5173
OLLAMA_PORT=11434

# Models. ollama-init pulls whatever is named here on the next `up` (first
# pull of a new model downloads it — a 2 GB model takes ~a minute).
# llama3.1:8b needs ~8 GB VRAM/RAM headroom; llama3.2:3b is the low-memory tier.
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Concurrency: MAP_WORKERS concurrent LLM mapping calls, matched by
# OLLAMA_NUM_PARALLEL server slots. Keep them equal; each slot costs KV-cache
# memory, so halve both on tight machines. The CPU profile auto-sizes both
# from machine RAM (4 slots >= 10 GiB, else 2) when they are left unset /
# MAP_WORKERS=-1 — setting values here overrides that.
OLLAMA_NUM_PARALLEL=4
MAP_WORKERS=4

# Memory trims applied by the cpu/basic profiles (see docker-compose.cpu.yml):
# 8-bit KV-cache (halves per-slot context memory; needs flash attention) and
# no llama.cpp host-RAM prompt cache (its default limit is 8 GiB — an OOM
# risk on small machines). Uncomment to change/disable.
# OLLAMA_FLASH_ATTENTION=1
# OLLAMA_KV_CACHE_TYPE=q8_0   # f16 restores the unquantized cache
# LLAMA_ARG_CACHE_RAM=0       # MiB of prompt cache; -1 = llama.cpp default

# Mapping prompt size: retrieval candidates offered per chunk, and chars of
# each candidate's description kept in the prompt. Prompt reading (prefill)
# is ~60-70% of a chunk's CPU cost — 6/170 measured ~22% faster but changed
# the verdicts (accuracy regression), so every profile keeps these
# full-quality defaults; treat lowering them as an eval-harness experiment.
# llama.cpp threads per request: 0 = Ollama's default, -1 = auto-match the
# CPU profiles' core pinning (fixes thread oversubscription in VMs).
MAP_CANDIDATES=8
MAP_DESC_CHARS=250
MAP_NUM_THREAD=0

# -1 pins models in (V)RAM forever (warm runs always); a duration like `5m`
# releases the memory after idle time instead.
OLLAMA_KEEP_ALIVE=-1

# Skip remediation/boilerplate sections at indexing (false = ablation run).
SECTION_FILTER=true

# Inject ATT&CK ids cited literally in report text (e.g. "[T1573]") into that
# chunk's mapping candidates (false = pure-retrieval ablation run).
EXPLICIT_IDS=true

# Data / storage paths (inside containers)
UPLOAD_DIR=/data/uploads
LAYERS_DIR=/data/layers
CHROMA_PERSIST_DIR=/data/chroma
ATTACK_STIX_DIR=/data/attack
