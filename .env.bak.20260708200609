# Backend / frontend ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Ollama
OLLAMA_PORT=11434
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Data / storage paths (inside containers)
UPLOAD_DIR=/data/uploads
CHROMA_PERSIST_DIR=/data/chroma
ATTACK_STIX_DIR=/data/attack



# Full-power profile for this machine (32 GB + RTX 4060) — see .env.lowmem
# for the 16 GB profile. Keep OLLAMA_NUM_PARALLEL and MAP_WORKERS in sync.
OLLAMA_NUM_PARALLEL=4
MAP_WORKERS=4
OLLAMA_KEEP_ALIVE=-1
